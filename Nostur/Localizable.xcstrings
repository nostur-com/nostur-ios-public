        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La cuenta de invitado ya sigue a algunas personas. Puede leer publicaciones y ver perfiles, pero no puede publicar ni darle me gusta a cosas hasta que cree una nueva cuenta usted mismo."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
